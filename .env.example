# Shared secret used by the Replicate-backed plugins in this repo.
# You can either:
# 1. export this variable in your shell before running the scripts, or
# 2. copy it into a plugin-specific `.env.local` file.
#
# Supported plugin-local env files:
# - plugins/replicate-model-runner/.env.local
# - plugins/prunaai-p-image-generator/.env.local
# - plugins/prunaai-p-image-edit-generator/.env.local
# - plugins/prunaai-p-video-generator/.env.local

REPLICATE_API_TOKEN=your_replicate_api_token_here
